# Apache: redirige todas las peticiones a index.php
# Hostinger usa Apache con mod_rewrite habilitado

Options -Indexes -MultiViews
DirectoryIndex index.php

# ── CORS y Cabeceras en Apache (Respaldo por si PHP no intercepta OPTIONS) ──
<IfModule mod_headers.c>
    SetEnvIf Origin "^http(s)?://(www\.)?(catalogo\.tiendaintima\.com|tiendaintima\.com|localhost:4200|127\.0\.0\.1:4200)$" AccessControlAllowOrigin=$0
    Header always set Access-Control-Allow-Origin %{AccessControlAllowOrigin}e env=AccessControlAllowOrigin
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, Accept"
    Header always set Access-Control-Allow-Credentials "true"

    # Encabezados de Seguridad
    Header always set X-Content-Type-Options    "nosniff"
    Header always set X-Frame-Options           "DENY"
    Header always set X-XSS-Protection          "1; mode=block"
    Header always set Referrer-Policy           "strict-origin-when-cross-origin"
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Preservar y reenviar cabecera Authorization (crítico en Apache/Hostinger para JWT)
    RewriteCond %{HTTP:Authorization} ^(.*)
    RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

    # Responder preflight OPTIONS inmediatamente con 200 OK si es necesario
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L]

    # Servir archivos y directorios físicos directamente
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Todo lo demás → index.php
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Seguridad: bloquear acceso a archivos sensibles
<FilesMatch "\.(env|json|lock|md|sql|sh|yml|yaml)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Comprimir respuestas JSON
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE text/plain
</IfModule>

# Cache control para respuestas API (sin caché)
<IfModule mod_headers.c>
    <FilesMatch "\.php$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    </FilesMatch>
</IfModule>
