{
    "name": "tiendaintima/catalog-api",
    "description": "API REST profesional — Catálogo Tienda Íntima",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "firebase/php-jwt": "^6.10",
        "cloudinary/cloudinary_php": "^2.13",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    },
    "scripts": {
        "install-dev": "composer install",
        "autoload": "composer dump-autoload -o"
    }
}
